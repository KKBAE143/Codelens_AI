# ============================================
# CodeLens AI - Environment Variables (Example)
# Copy this file to .env.local and fill in the values
# ============================================

# --- Database (Neon PostgreSQL) ---
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# --- GitHub OAuth ---
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Encryption ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
SESSION_SECRET=

# --- Cloudflare Workers AI ---
# Create a Workers AI token at https://dash.cloudflare.com/?to=/:account/ai/workers-ai
# Token needs Workers AI Read + Edit permissions
# You can keep using the shared pair below, or assign separate credentials per stage
# to spread free-tier usage across multiple Cloudflare accounts/tokens.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AUTH_TOKEN=

# Optional per-stage credential pool
# If set, stage-specific credentials take precedence over the shared pair above.
# You can also add numbered fallbacks like CLOUDFLARE_STAGE1_AUTH_TOKEN_2.
CLOUDFLARE_STAGE1_ACCOUNT_ID=
CLOUDFLARE_STAGE1_AUTH_TOKEN=
CLOUDFLARE_STAGE2_ACCOUNT_ID=
CLOUDFLARE_STAGE2_AUTH_TOKEN=
CLOUDFLARE_STAGE3_ACCOUNT_ID=
CLOUDFLARE_STAGE3_AUTH_TOKEN=
# Optional summary-stage override (otherwise it falls back to stage1, then shared)
CLOUDFLARE_SUMMARY_ACCOUNT_ID=
CLOUDFLARE_SUMMARY_AUTH_TOKEN=

# Optional per-task model overrides
COURSE_STAGE1_MODEL=
COURSE_STAGE2_MODEL=
COURSE_STAGE3_MODEL=
COURSE_SUMMARY_MODEL=

# --- Stripe ---
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (run seed script after setting up Stripe)
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# --- App URL ---
# Set to your Vercel deployment URL in production
# e.g. https://codelens.ai or https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:3000

# --- Inngest (optional) ---
# Get keys from https://cloud.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
